def read_rows(wb, sheet, max_rows=300):
    rows = []
    with wb.get_sheet(sheet) as ws:
        for i, row in enumerate(ws.rows()):
            if i >= max_rows:
                break
            rows.append([c.v for c in row])
    return rows

