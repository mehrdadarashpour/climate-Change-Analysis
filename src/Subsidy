def add_region_dots(ax, df_unified, y_pos, x_frac=-0.003, dot_size=7):
    trans = matplotlib.transforms.blended_transform_factory(
        ax.transAxes, ax.transData)
    for i, region in enumerate(df_unified['region']):
        col = REGION_COLORS.get(region, '#AAAAAA')
        ax.plot(x_frac, y_pos[i], 'o', color=col, markersize=dot_size,
                transform=trans, clip_on=False, zorder=15)

def decorate_bar_ax(ax, xlabel, xlim_max, note, title):
    ax.set_xlabel(xlabel, fontsize=8.5, labelpad=5)
    ax.set_xlim(0, xlim_max)
    ax.grid(axis='x', linestyle='--', linewidth=0.35, color='#CCCCCC', zorder=0)
    ax.set_axisbelow(True)
    ax.tick_params(axis='y', length=0, pad=10)
    ax.text(0.985, 0.028, note,
            transform=ax.transAxes, ha='right', va='bottom',
            fontsize=7.4, color='#555555',
            bbox=dict(boxstyle='round,pad=0.32', fc='#F6F6F6', ec='#CCCCCC', lw=0.5))
    ax.set_title(title, fontsize=10.5, fontweight='bold',
                 loc='left', pad=9, color='#111111')

